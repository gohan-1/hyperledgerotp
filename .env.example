# ============================================================
#  .env.example — Copy to .env and fill in your values
#  NEVER commit the real .env to version control!
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Security (CHANGE THESE IN PRODUCTION) ────────────────────
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=24h

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=otpuser
POSTGRES_PASSWORD=otppass
DATABASE_URL=postgresql://otpuser:otppass@postgres:5432/otpdb

# ── Redis (rate limiting + caching) ──────────────────────────
REDIS_PASSWORD=redispass
REDIS_URL=redis://:redispass@redis:6379

# ── Hyperledger Fabric ────────────────────────────────────────
FABRIC_CHANNEL=otp-channel
FABRIC_CHAINCODE=otp-contract
FABRIC_MSP_ID=Org1MSP
FABRIC_PEER_ENDPOINT=peer0.org1.otp.com:7051
CRYPTO_PATH=./crypto-config/peerOrganizations/org1.otp.com

# ── OTP Settings ─────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300        # 5 minutes
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=5              # max 5 OTP requests per window

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_PASSWORD=admin123
LOG_LEVEL=info
